```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
vendor/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Database
*.sql.bak
*.db-journal

# Coverage
coverage/
htmlcov/
.coverage

# OS generated files
.DS_Store
Thumbs.db
```